# Copy this file to `.env.local` (same folder) and fill in values.
# Combined reference for backend + frontend: ../env.example
# Azure Portal: App registrations > your app > Overview + Certificates & secrets

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Generate: npx auth secret   OR   openssl rand -base64 32
NEXTAUTH_SECRET=

# Must match the URL you use in the browser (OAuth redirect)
NEXTAUTH_URL=http://localhost:3000

# Flask API (rewrites /flask/* → this origin). Defaults to http://127.0.0.1:5000 if unset.
# FLASK_BACKEND_URL=http://127.0.0.1:5000

# In Azure app registration, add redirect URI:
# http://localhost:3000/api/auth/callback/azure-ad
