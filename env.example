# =============================================================================
# FGF IT Case Competition — environment variable reference
# =============================================================================
# This repo uses two separate env files (do not merge into one file).
#
#   Flask API:  copy the BACK END block to  Back End/.env
#   Next.js:    copy the FRONT END block to  next-shadcn-dashboard-starter/.env.local
#
# Canonical templates (same content, split by app):
#   Back End/.env.example
#   next-shadcn-dashboard-starter/.env.example
# =============================================================================

# ---------------------------------------------------------------------------
# BACK END — save as: Back End/.env
# ---------------------------------------------------------------------------

# Azure DevOps (required for REST API)
AZURE_DEVOPS_ORG=your-organization-name
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_PAT=your-personal-access-token

# Optional: bootstrap JWT for Graph/Outlook; usually set at runtime via POST /api/receive-token
AZURE_DEVOPS_JWT_TOKEN=

# OpenAI (required for GPT / chatbot / task-assignment features)
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# FRONT END — save as: next-shadcn-dashboard-starter/.env.local
# ---------------------------------------------------------------------------
# Azure Portal: App registrations > your app > Overview + Certificates & secrets
# Redirect URI (Web): http://localhost:3000/api/auth/callback/azure-ad

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Generate: npx auth secret   OR   openssl rand -base64 32
NEXTAUTH_SECRET=

# Must match the URL you use in the browser (OAuth redirect)
NEXTAUTH_URL=http://localhost:3000
