# Copy to ".env" in this folder (Back End/). Never commit .env.
# Combined reference for backend + frontend: ../env.example

# Azure DevOps (required for REST API)
AZURE_DEVOPS_ORG=your-organization-name
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_PAT=your-personal-access-token

# Optional: bootstrap JWT for Graph/Outlook; usually set at runtime via /api/receive-token
AZURE_DEVOPS_JWT_TOKEN=

# OpenAI (required for GPT routes)
OPENAI_API_KEY=
